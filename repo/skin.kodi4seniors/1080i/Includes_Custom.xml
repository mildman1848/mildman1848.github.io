          <width>840</width>
          <height>72</height>
          <font>font_body</font>
          <textcolor>FF151515</textcolor>
          <aligny>center</aligny>
          <label>$INFO[ListItem.Property(description)]</label>
        </control>
      </focusedlayout>
      <content>
        <item>
          <label>Technikmodus beenden</label>
          <onclick>Skin.Reset(technician_mode)</onclick>
          <onclick>ActivateWindow(Home)</onclick>
          <property name="description">Sperrt den Technikbereich wieder und kehrt zur vereinfachten Startseite zurueck.</property>
        </item>
        <item>
          <label>Mediatheken vorbereiten</label>
          <onclick>ActivateWindow(1112)</onclick>
          <property name="description">ARD, ZDF, Arte und weitere Mediatheken gebuendelt pruefen und vorbereiten.</property>
        </item>
        <item>
          <label>Technik-PIN aendern</label>
          <onclick>Skin.SetNumeric(technician_pin)</onclick>
          <property name="description">Aendert die PIN fuer den Zugang zum Technikbereich. Standard ist 1848.</property>
        </item>
        <item>
          <label>Bibliothek vorbereiten</label>
          <onclick>ActivateWindow(MediaSettings)</onclick>
          <property name="description">Quellen, Metadaten und spaetere Bibliothekswege fuer Filme und Serien einrichten.</property>
        </item>
        <item>
          <label>Live-TV einrichten</label>
          <onclick>ActivateWindow(PVRSettings)</onclick>
          <property name="description">PVR-Backend, Sender und EPG einmalig einrichten.</property>
        </item>
        <item>
          <label>Interface</label>
          <onclick>ActivateWindow(InterfaceSettings)</onclick>
          <property name="description">Sprache, Region, Bildschirmschoner und Bedienoberflaeche anpassen.</property>
        </item>
        <item>
          <label>System</label>
          <onclick>ActivateWindow(SystemSettings)</onclick>
          <property name="description">Audio, Anzeige, Stromoptionen und Hardware-bezogene Einstellungen.</property>
        </item>
        <item>
          <label>Dienste und Netzwerk</label>
          <onclick>ActivateWindow(ServiceSettings)</onclick>
          <property name="description">Netzwerkdienste und Fernzugriff konfigurieren.</property>
        </item>
        <item>
          <label>Player</label>
          <onclick>ActivateWindow(PlayerSettings)</onclick>
          <property name="description">Wiedergabeverhalten fuer Video, Audio und Untertitel festlegen.</property>
        </item>
        <item>
          <label>Medien</label>
          <onclick>ActivateWindow(MediaSettings)</onclick>
          <property name="description">Bibliotheken, Metadaten und Quellen verwalten.</property>
        </item>
        <item>
          <label>Add-ons</label>
          <onclick>ActivateWindow(AddonBrowser)</onclick>
          <property name="description">Mediatheken und weitere Kodi-Add-ons installieren oder aktualisieren.</property>
        </item>
        <item>
          <label>Zur Startseite</label>
          <onclick>ActivateWindow(Home)</onclick>
          <property name="description">Zur vereinfachten Startseite zurueckkehren.</property>
        </item>
      </content>
