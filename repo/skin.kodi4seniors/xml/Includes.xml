  <include name="HomeDetailPanel">
    <control type="group">
      <left>90</left>
      <top>810</top>
      <width>1540</width>
      <height>190</height>
      <control type="image">
        <left>0</left>
        <top>0</top>
        <width>1540</width>
        <height>190</height>
        <colordiffuse>D0263138</colordiffuse>
        <texture>resources/panel.png</texture>
        <aspectratio>stretch</aspectratio>
      </control>
      <control type="label">
        <left>48</left>
        <top>28</top>
        <width>1440</width>
        <height>52</height>
        <font>font_button</font>
        <textcolor>FFF0B04A</textcolor>
        <label>Einfacher Start</label>
      </control>
      <control type="textbox">
        <left>48</left>
        <top>86</top>
        <width>1440</width>
        <height>82</height>
        <font>font_body_large</font>
        <textcolor>FFE6DFD4</textcolor>
        <label>Waehle eine der vier grossen Kacheln. Fernsehen zeigt das laufende Programm. Mediatheken oeffnet die Sender-Add-ons. Bibliothek fuehrt zu eigenen Inhalten. Einstellungen sind fuer die betreuende Person gedacht.</label>
      </control>
      <control type="label">
        <left>48</left>
        <top>150</top>
        <width>1440</width>
        <height>28</height>
        <font>font_body</font>
        <textcolor>FFF7F3EA</textcolor>
        <label>Fernsehen ist eingerichtet.</label>
        <visible>Control.HasFocus(1101) + System.HasPVRAddon</visible>
      </control>
      <control type="label">
        <left>48</left>
        <top>150</top>
        <width>1440</width>
        <height>28</height>
        <font>font_body</font>
        <textcolor>FFF7F3EA</textcolor>
        <label>Fernsehen muss noch eingerichtet werden.</label>
        <visible>Control.HasFocus(1101) + !System.HasPVRAddon</visible>
      </control>
      <control type="label">
        <left>48</left>
        <top>150</top>
        <width>1440</width>
        <height>28</height>
        <font>font_body</font>
        <textcolor>FFF7F3EA</textcolor>
        <label>ARD, ZDF, Arte und weitere Mediatheken schnell erreichen.</label>
        <visible>Control.HasFocus(1102)</visible>
      </control>
      <control type="label">
        <left>48</left>
        <top>150</top>
        <width>1440</width>
        <height>28</height>
        <font>font_body</font>
        <textcolor>FFF7F3EA</textcolor>
        <label>Eigene Filme, Serien und Videos oeffnen.</label>
        <visible>Control.HasFocus(1103)</visible>
      </control>
      <control type="label">
        <left>48</left>
        <top>150</top>
        <width>1440</width>
        <height>28</height>
        <font>font_body</font>
        <textcolor>FFF7F3EA</textcolor>
        <label>Nur fuer Einrichtung, Wartung und technische Anpassungen.</label>
        <visible>Control.HasFocus(1104)</visible>
      </control>
    </control>
  </include>

  <include name="SettingsMenuList">
    <control type="list" id="2100">
      <left>90</left>
      <top>220</top>
      <width>1740</width>
      <height>740</height>
      <onup>2100</onup>
      <ondown>2100</ondown>
      <scrolltime>180</scrolltime>
      <itemlayout width="1740" height="96">
        <control type="image">
          <left>0</left>
          <top>6</top>
          <width>1660</width>
          <height>84</height>
          <colordiffuse>F0282E37</colordiffuse>
          <texture>resources/panel.png</texture>
        </control>
        <control type="label">
          <left>32</left>
          <top>8</top>
          <width>720</width>
          <height>72</height>
          <font>font_button</font>
          <textcolor>FFF4F0E8</textcolor>
          <aligny>center</aligny>
          <label>$INFO[ListItem.Label]</label>
        </control>
        <control type="label">
          <left>760</left>
          <top>8</top>
          <width>840</width>
          <height>72</height>
          <font>font_body</font>
          <textcolor>FFD9D2C4</textcolor>
          <aligny>center</aligny>
          <label>$INFO[ListItem.Property(description)]</label>
        </control>
      </itemlayout>
      <focusedlayout width="1740" height="96">
        <control type="image">
          <left>0</left>
          <top>0</top>
          <width>1690</width>
          <height>96</height>
          <colordiffuse>FFF0B04A</colordiffuse>
          <texture>resources/panel.png</texture>
        </control>
        <control type="label">
          <left>32</left>
          <top>12</top>
          <width>720</width>
          <height>72</height>
          <font>font_button</font>
          <textcolor>FF151515</textcolor>
          <aligny>center</aligny>
          <label>$INFO[ListItem.Label]</label>
        </control>
        <control type="label">
          <left>760</left>
          <top>12</top>
          <width>840</width>
          <height>72</height>
          <font>font_body</font>
          <textcolor>FF151515</textcolor>
          <aligny>center</aligny>
          <label>$INFO[ListItem.Property(description)]</label>
        </control>
      </focusedlayout>
      <content>
        <item>
          <label>Live-TV einrichten</label>
          <onclick>ActivateWindow(PVRSettings)</onclick>
          <property name="description">PVR-Backend, Sender und EPG einmalig einrichten.</property>
        </item>
        <item>
          <label>Interface</label>
          <onclick>ActivateWindow(InterfaceSettings)</onclick>
          <property name="description">Sprache, Region, Bildschirmschoner und Bedienoberflaeche anpassen.</property>
        </item>
        <item>
          <label>System</label>
          <onclick>ActivateWindow(SystemSettings)</onclick>
          <property name="description">Audio, Anzeige, Stromoptionen und Hardware-bezogene Einstellungen.</property>
        </item>
        <item>
          <label>Dienste und Netzwerk</label>
          <onclick>ActivateWindow(ServiceSettings)</onclick>
          <property name="description">Netzwerkdienste und Fernzugriff konfigurieren.</property>
        </item>
        <item>
          <label>Player</label>
          <onclick>ActivateWindow(PlayerSettings)</onclick>
          <property name="description">Wiedergabeverhalten fuer Video, Audio und Untertitel festlegen.</property>
        </item>
        <item>
          <label>Medien</label>
          <onclick>ActivateWindow(MediaSettings)</onclick>
          <property name="description">Bibliotheken, Metadaten und Quellen verwalten.</property>
        </item>
        <item>
          <label>Add-ons</label>
          <onclick>ActivateWindow(AddonBrowser)</onclick>
          <property name="description">Mediatheken und weitere Kodi-Add-ons installieren oder aktualisieren.</property>
        </item>
        <item>
          <label>Zur Startseite</label>
          <onclick>ActivateWindow(Home)</onclick>
          <property name="description">Zur vereinfachten Startseite zurueckkehren.</property>
        </item>
      </content>
    </control>
  </include>
</includes>
