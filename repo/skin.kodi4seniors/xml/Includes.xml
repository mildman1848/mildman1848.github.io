  <include name="HomeTileBase">
    <param name="id" value="0" />
    <param name="left" value="0" />
    <param name="top" value="0" />
    <param name="label" value="" />
    <param name="icon" value="icons/home/default.png" />
    <param name="onclick" value="" />
    <param name="onleft" value="0" />
    <param name="onright" value="0" />
    <param name="onup" value="0" />
    <param name="ondown" value="0" />
    <definition>
      <control type="button" id="$PARAM[id]">
        <left>$PARAM[left]</left>
        <top>$PARAM[top]</top>
        <width>760</width>
        <height>260</height>
        <onleft>$PARAM[onleft]</onleft>
        <onright>$PARAM[onright]</onright>
        <onup>$PARAM[onup]</onup>
        <ondown>$PARAM[ondown]</ondown>
        <texturenofocus colordiffuse="D0333F49">resources/panel.png</texturenofocus>
        <texturefocus colordiffuse="FFF0B04A">resources/panel.png</texturefocus>
        <onclick>$PARAM[onclick]</onclick>
        <label></label>
      </control>
      <control type="image">
        <left>$PARAM[left]</left>
        <top>$PARAM[top]</top>
        <width>760</width>
        <height>260</height>
        <texture colordiffuse="18FFFFFF">$PARAM[icon]</texture>
        <visible>!Control.HasFocus($PARAM[id])</visible>
      </control>
      <control type="image">
        <left>$PARAM[left]</left>
        <top>$PARAM[top]</top>
        <width>760</width>
        <height>260</height>
        <texture colordiffuse="22FFFFFF">$PARAM[icon]</texture>
        <visible>Control.HasFocus($PARAM[id])</visible>
      </control>
      <control type="label">
        <left>$PARAM[left]</left>
        <top>$PARAM[top]</top>
        <width>760</width>
        <height>260</height>
        <align>center</align>
        <aligny>center</aligny>
        <font>font_title</font>
        <textcolor>FFF7F3EA</textcolor>
        <label>$PARAM[label]</label>
        <visible>!Control.HasFocus($PARAM[id])</visible>
      </control>
      <control type="label">
        <left>$PARAM[left]</left>
        <top>$PARAM[top]</top>
        <width>760</width>
        <height>260</height>
        <align>center</align>
        <aligny>center</aligny>
        <font>font_title</font>
        <textcolor>FF151515</textcolor>
        <label>$PARAM[label]</label>
        <visible>Control.HasFocus($PARAM[id])</visible>
      </control>
    </definition>
  </include>

