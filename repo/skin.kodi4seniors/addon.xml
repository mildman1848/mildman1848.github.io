<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="skin.kodi4seniors" version="0.1.17" name="Kodi4Seniors" provider-name="mildman1848">
  <requires>
    <import addon="xbmc.gui" version="5.17.0" />
    <import addon="xbmc.python" version="3.0.0" />
  </requires>
  <extension point="xbmc.gui.skin" debugging="false">
    <res width="1920" height="1080" aspect="16:9" default="true" folder="1080i" />
  </extension>
  <extension point="xbmc.addon.metadata">
    <platform>all</platform>
    <license>GPL-3.0-or-later</license>
    <source>https://github.com/mildman1848/kodi-for-seniors</source>
    <website>https://github.com/mildman1848/kodi-for-seniors</website>
    <assets>
      <icon>resources/icon.png</icon>
      <fanart>fanart.jpg</fanart>
      <screenshot>resources/screenshot-home.jpg</screenshot>
    </assets>
    <summary lang="de_DE">Senior-friendly Kodi Skin</summary>
    <summary lang="en_GB">Senior-friendly Kodi Skin</summary>
    <description lang="de_DE">Grosse Kacheln, Live-TV, Mediatheken, Bibliothek und einfacher Zugang fuer Senioren.</description>
    <description lang="en_GB">Large tiles, Live TV, mediatheken, library access and simplified operation for seniors.</description>
  </extension>
</addon>
