<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="skin.kodi4seniors" name="Kodi fuer Senioren" provider-name="mildman1848" version="0.1.12">
  <requires>
    <import addon="xbmc.gui" version="5.17.0" />
  </requires>
  <extension point="xbmc.gui.skin" debugging="false">
    <res width="1920" height="1080" aspect="16:9" default="true" folder="xml" />
  </extension>
  <extension point="xbmc.addon.metadata">
    <platform>all</platform>
    <license>GPL-3.0-or-later</license>
    <source>https://github.com/mildman1848/kodi-for-seniors</source>
    <website>https://github.com/mildman1848/kodi-for-seniors</website>
    <assets>
      <icon>resources/icon.png</icon>
      <fanart>resources/fanart.jpg</fanart>
      <screenshot>resources/screenshot-home.jpg</screenshot>
    </assets>
    <summary lang="de_DE">Kodi-Skin mit grossen Schaltflaechen fuer Senioren</summary>
    <summary lang="en_GB">Kodi skin with large controls for seniors</summary>
    <description lang="de_DE">Reduzierter Kodi-Skin fuer seniorengerechte Bedienung mit Fokus auf Live-TV, TV-Guide mit EPG und einfachem Zugang zu Mediatheken.</description>
    <description lang="en_GB">Reduced Kodi skin for senior-friendly operation with focus on live TV, EPG guide and simple access to broadcaster catch-up services.</description>
  </extension>
</addon>
